# --- Database (Amazon Aurora PostgreSQL; system of record) ---
# Local dev points at the docker-compose Postgres. In Aurora, swap in the writer endpoint.
DATABASE_URL=postgres://pathhome:pathhome@localhost:5432/pathhome
# TLS policy: disable | require | verify-full  (default: disable in dev, verify-full in prod)
DATABASE_SSL=disable
# PEM contents of the Aurora CA bundle; required when DATABASE_SSL=verify-full.
DATABASE_CA_CERT=
# Max pooled connections.
PGPOOL_MAX=10

# --- Voice (AssemblyAI) ---
ASSEMBLYAI_API_KEY=

# --- Enrichment (Anthropic) ---
ANTHROPIC_API_KEY=
# Model used for structured extraction; defaults to claude-haiku-4-5-20251001.
ENRICHMENT_MODEL=claude-haiku-4-5-20251001

# --- Privacy (surfaced as config, never hardcoded) ---
# Transcripts are redacted before persistence and expire after this many hours.
TRANSCRIPT_TTL_HOURS=72
# Assert the AssemblyAI account is opted out of model training; keep only billing/logging metadata.
OPT_OUT_MODEL_TRAINING=true

# --- Phone edge (optional) ---
# When false, the browser voice path is the only channel and must stay green.
TWILIO_ENABLED=false
